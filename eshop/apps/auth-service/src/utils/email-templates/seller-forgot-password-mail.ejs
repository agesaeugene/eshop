<!DOCTYPE html>
<html>
<head>
    <title>SokoJamo Seller Password Reset</title>
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <style type="text/css">
        body {
            margin: 0;
            padding: 0;
            min-width: 100%;
            font-family: Arial, sans-serif;
            font-size: 16px;
            line-height: 1.5;
            background-color: #f4f4f4;
            color: #222222;
        }

        a {
            color: #ffffff;
            text-decoration: none;
        }

        h1 {
            font-size: 24px;
            font-weight: 700;
            line-height: 1.25;
            margin-top: 0;
            margin-bottom: 15px;
            text-align: center;
        }

        h2 {
            text-align: center;
            color: #0070f3;
            font-size: 32px;
            letter-spacing: 4px;
            margin: 24px 0;
        }

        p {
            margin-top: 0;
            margin-bottom: 24px;
        }

        table td {
            vertical-align: top;
        }

        .email-wrapper {
            max-width: 600px;
            margin: 0 auto;
        }

        .email-header {
            background-color: #0070f3;
            padding: 24px;
            color: #ffffff;
        }

        .email-body {
            background-color: #ffffff;
            padding: 24px;
        }

        .email-footer {
            background-color: #565656;
            padding: 24px;
        }

        .button {
            display: inline-block;
            padding: 12px 24px;
            background-color: #0070f3;
            color: #ffffff;
            font-size: 16px;
            border-radius: 4px;
            font-weight: 700;
            text-align: center;
            text-decoration: none;
        }

        .seller-badge {
            display: inline-block;
            background-color: #ffffff;
            color: #0070f3;
            padding: 6px 14px;
            border-radius: 20px;
            font-size: 14px;
            font-weight: bold;
            margin-top: 10px;
        }
    </style>
</head>
<body>
    <div class="email-wrapper">
        <div class="email-header">
            <h1>Seller Password Reset Request</h1>

            <div style="text-align: center;">
                <span class="seller-badge">SokoJamo Seller Portal</span>
            </div>
        </div>

        <div class="email-body">
            <p>Hello <%= name %>,</p>

            <p>
                We received a request to reset the password for your 
                SokoJamo Seller account.
            </p>

            <p>
                Use the verification code below to continue resetting your password:
            </p>

            <h2><%= otp %></h2>

            <p>
                This verification code will expire in 5 minutes for security purposes.
            </p>

            <p>
                If you did not request a password reset, please ignore this email.
                Your seller account will remain secure.
            </p>

            <p>
                For additional assistance, contact the SokoJamo seller support team.
            </p>
        </div>

        <div class="email-footer">
            <p style="color: #ffffff; text-align: center; margin-bottom: 12px;">
                &copy; <%= new Date().getFullYear() %> SokoJamo Seller Platform. 
                All rights reserved.
            </p>

            <p style="color: #ffffff; text-align: center; margin-bottom: 0;">
                Need help? Contact us at
                <a href="mailto:sellersupport@SokoJamo.com" style="color: #4da3ff;">
                    sellersupport@SokoJamo.com
                </a>
            </p>
        </div>
    </div>
</body>
</html>